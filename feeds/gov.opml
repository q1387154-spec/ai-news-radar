<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
    <title>物流政策情报雷达 - 精简高价值源池</title>
    <owner>克劳 (Policy Scout)</owner>
    <dateCreated>2026-05-16</dateCreated>
    <description>物流/快递企业政策申报专用源池，按优先级排序</description>
  </head>
  <body>

    <!-- ================================================
         第一优先级：上海经信委（最核心）
         ================================================ -->

    <outline text="上海经信委">
      <outline text="上海经信委-通知资金补贴公告"
        title="上海经信委-通知资金补贴公告"
        type="rss"
        xmlUrl="https://www.sheitc.sh.gov.cn/zxzjtzgg/index.html"
        htmlUrl="https://www.sheitc.sh.gov.cn/zxzjtzgg/index.html"
        category="municipal"
        level="P0"
        keywords="AI,数字化,技改,专精特新,工业互联网,数字化转型,算力,产业补贴,专项资金"/>
      <outline text="上海经信委-公示公告"
        title="上海经信委-公示公告"
        type="rss"
        xmlUrl="https://sheitc.sh.gov.cn/gg/index.html"
        htmlUrl="https://sheitc.sh.gov.cn/gg/index.html"
        category="municipal"
        level="P0"
        keywords="专项资金,技改,数字化,专精特新"/>
      <outline text="上海经信委-最新公开信息"
        title="上海经信委-最新公开信息"
        type="rss"
        xmlUrl="https://www.sheitc.sh.gov.cn/zxgkxx/index.html"
        htmlUrl="https://www.sheitc.sh.gov.cn/zxgkxx/index.html"
        category="municipal"
        level="P0"
        keywords="专项资金,产业,数字化转型"/>
    </outline>

    <!-- ================================================
         第二优先级：上海市发改委（产业/物流相关）
         ================================================ -->

    <outline text="上海发改委">
      <outline text="上海发改委-价格管理通知"
        title="上海发改委-价格管理通知"
        type="rss"
        xmlUrl="https://fgw.sh.gov.cn/fgw_jggl/"
        htmlUrl="https://fgw.sh.gov.cn/fgw_jggl/"
        category="municipal"
        level="P0"
        keywords="重大项目,产业政策,物流,交通"/>
    </outline>

    <!-- ================================================
         第三优先级：青浦区政府（地理最相关）
         ================================================ -->

    <outline text="青浦区政府">
      <outline text="青浦-公示公告"
        title="青浦区公示公告"
        type="rss"
        xmlUrl="https://www.shqp.gov.cn/shqp/gsgg/"
        htmlUrl="https://www.shqp.gov.cn/shqp/gsgg/"
        category="district"
        level="P0"
        keywords="专项资金,重大项目,低空经济,长三角"/>
      <outline text="青浦-政务公开"
        title="青浦区政务公开"
        type="rss"
        xmlUrl="https://www.shqp.gov.cn/shqp/zwgk/index.html"
        htmlUrl="https://www.shqp.gov.cn/shqp/zwgk/index.html"
        category="district"
        level="P0"
        keywords="专项资金,重大项目,低空经济"/>
    </outline>

    <!-- ================================================
         第四优先级：国家工信部（政策方向参考）
         ================================================ -->

    <outline text="工信部">
      <outline text="工信部-政策文件"
        title="工信部-政策文件"
        type="rss"
        xmlUrl="https://www.miit.gov.cn/zwgk/zcwj/"
        htmlUrl="https://www.miit.gov.cn/zwgk/zcwj/"
        category="national"
        level="P1"
        keywords="数字化转型,人工智能,专精特新,工业互联网,技术改造,算力"/>
    </outline>

    <!-- ================================================
         第五优先级：国家邮政局（快递行业主管）
         ================================================ -->

    <outline text="国家邮政局">
      <outline text="国家邮政局-通知公告"
        title="国家邮政局-通知公告"
        type="rss"
        xmlUrl="http://www.spb.gov.cn/zwgk/tz/"
        htmlUrl="http://www.spb.gov.cn/zwgk/tz/"
        category="national"
        level="P0"
        keywords="无人配送车,智慧快递,无人机物流,末端配送"/>
    </outline>

    <!-- ================================================
         第六优先级：人社部/局（稳岗补贴）
         ================================================ -->

    <outline text="上海人社局">
      <outline text="上海人社局-公示公告"
        title="上海人社局-公示公告"
        type="rss"
        xmlUrl="https://rsj.sh.gov.cn/tgsgg_17341/index.html"
        htmlUrl="https://rsj.sh.gov.cn/tgsgg_17341/index.html"
        category="municipal"
        level="P1"
        keywords="稳岗,技能补贴,创业补贴,就业见习"/>
    </outline>

    <!-- ================================================
         专题：低空经济
         ================================================ -->

    <outline text="低空经济">
      <outline text="民航局-政策"
        title="中国民用航空局-政策文件"
        type="rss"
        xmlUrl="https://www.caac.gov.cn/zwgk/zcwj/"
        htmlUrl="https://www.caac.gov.cn/zwgk/zcwj/"
        category="uav"
        level="P0"
        keywords="低空经济,无人机,空域改革,eVTOL,适航,通航"/>
    </outline>

  </body>
</opml>
